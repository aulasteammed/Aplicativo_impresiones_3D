# ============================================================================
# Aula STEAM — Aplicativo de Impresión 3D
# Copie este archivo como ".env.local" y complete los valores.
# Mientras falten valores, la app corre en MODO DEMO con datos de ejemplo.
# Guía paso a paso: README.md
# ============================================================================

# --- 1. Google Sheets (service account) -------------------------------------
# JSON COMPLETO de la service account en una sola línea (recomendado),
# o alternativamente la ruta del archivo en GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=C:\ruta\al\archivo\credenciales.json

# ID de cada spreadsheet (la parte entre /d/ y /edit de la URL)
SHEET_ID_SOLICITUDES=
SHEET_ID_HISTORIAL=
SHEET_ID_INVENTARIO=

# Nombres de las pestañas (solo cambiar si se renombraron en los Sheets)
# TAB_SOLICITUDES=Respuestas de formulario 1
# TAB_HISTORIAL=Historial

# --- 2. Google Form (crear solicitudes desde la app) ------------------------
# URL del formulario terminada en /formResponse
FORM_URL=
# IDs de cada campo (entry.XXXXXXX). Cómo obtenerlos: README.md sección 4.
FORM_ENTRY_NOMBRE=
FORM_ENTRY_CONTACTO=
FORM_ENTRY_ROL=
FORM_ENTRY_PROGRAMA=
FORM_ENTRY_MOTIVO=
FORM_ENTRY_SERVICIO=
FORM_ENTRY_DESCRIPCION=
FORM_ENTRY_OBJETIVO=
FORM_ENTRY_FECHA=

# --- 3. Análisis de capturas del slicer -------------------------------------
# El análisis es por OCR LOCAL (Tesseract.js), sin IA ni claves de API.
# No requiere configuración. La primera vez descarga el modelo de OCR (~5 MB).

# --- 4. Correo — Apps Script Web App (cuenta Aula_steam_med@unal.edu.co) ----
# URL de la implementación del Web App (apps-script/Codigo.gs)
APPS_SCRIPT_URL=
# El mismo token configurado en TOKEN_SECRETO dentro de Codigo.gs
APPS_SCRIPT_TOKEN=

# Correo del aula (notificaciones internas)
# CORREO_AULA=Aula_steam_med@unal.edu.co
